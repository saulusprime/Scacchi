# ===== Esempio di variabili d'ambiente per Scacchi =====
# Copia questo file in ".env" e adatta i valori. NON committare il file ".env" reale.
# I nomi qui sotto sono indicativi: saranno consolidati con lo scaffold del codice.

# ----- Backend (FastAPI) -----
# In sviluppo è sufficiente SQLite; in produzione usare PostgreSQL.
DATABASE_URL=sqlite:///./scacchi.db
# Esempio PostgreSQL:
# DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/scacchi
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Chiave per firmare i token/sessioni (genera un valore casuale robusto)
SECRET_KEY=cambia-questo-valore

# Token per l'interfaccia super admin (modifica dei parametri di programma).
# Senza questo valore la modifica dei parametri è disabilitata.
ADMIN_TOKEN=cambia-questo-token-admin

# ----- Giocatore IA (Qwen / DashScope, formato OpenAI-compatible) -----
# Se la chiave è assente, l'IA usa un giocatore locale ottimale (minimax) come fallback.
QWEN_API_KEY=
# Endpoint: internazionale di default. Per la Cina:
# https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# ----- Frontend (Django) -----
DJANGO_SECRET_KEY=cambia-questo-valore
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# URL con cui il frontend Django raggiunge il backend FastAPI
BACKEND_API_URL=http://127.0.0.1:8000

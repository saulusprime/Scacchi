#: web/templates/web/home.html:3
msgid "OmniBoard — Piattaforma di giochi da tavolo"
msgstr "OmniBoard — Board game platform"

#: web/templates/web/home.html:7
msgid ""
"Gioca a scacchi e ad altri giochi da tavolo a turni — dama, tris, forza 4 — "
"tramite un unico motore. Registrati, sfida gli altri giocatori e scala le "
"classifiche."
msgstr ""
"Play chess and other turn-based board games — draughts, tic-tac-toe, connect "
"four — on a single engine. Register, challenge other players and climb the "
"rankings."

#: web/templates/web/home.html:10
msgid "Crea un giocatore"
msgstr "Create a player"

#: web/templates/web/home.html:11
msgid "Vedi le classifiche"
msgstr "See the rankings"

#: web/templates/web/home.html:13
msgid "Puoi giocare in due sullo stesso schermo oppure sfidare l'IA."
msgstr "You can play together on the same screen or challenge the AI."

